{
  "family": "netflix-clone-task",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "executionRoleArn": "arn:aws:iam::342480083590:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "netflix-clone",
      "image": "342480083590.dkr.ecr.us-east-1.amazonaws.com/netflixrepoimg:latest",
      "cpu": 256,
      "memory": 512,
      "portMappings": [
        { "containerPort": 80, "hostPort": 80, "protocol": "tcp" }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/netflix-clone",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
